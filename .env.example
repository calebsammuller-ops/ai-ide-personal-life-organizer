# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# ANTHROPIC (CLAUDE AI) CONFIGURATION
# ===========================================
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# ===========================================
# WEB SEARCH API CONFIGURATION (Optional)
# ===========================================
# Enable web search for AI to find and validate real-time information
# Configure at least ONE of these for web search capability:

# Brave Search API (Recommended - affordable and fast)
# Get your key from https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Tavily API (Designed for AI applications)
# Get your key from https://tavily.com
TAVILY_API_KEY=

# SerpAPI (Google search results)
# Get your key from https://serpapi.com
SERPAPI_KEY=

# ===========================================
# STRIPE PAYMENT CONFIGURATION
# ===========================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret from Stripe dashboard
# Create at https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Product and Price IDs (create in Stripe dashboard)
STRIPE_PRO_PRODUCT_ID=prod_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_PREMIUM_PRODUCT_ID=prod_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...

# ===========================================
# SENTRY ERROR MONITORING
# ===========================================
# Get your DSN from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===========================================
# UPSTASH REDIS (Rate Limiting)
# ===========================================
# Optional - for distributed rate limiting in production
# Get these from https://upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ===========================================
# OPENAI (Text-to-Speech Voice)
# ===========================================
# Required for voice assistant feature
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0
NODE_ENV=development

# Logging level (debug, info, warn, error)
LOG_LEVEL=debug
